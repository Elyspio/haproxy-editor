{
	"name": "front-vite",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vp dev",
		"typecheck": "tsc --project ./config/tsconfig.app.json  -w",
		"build": "vp check --fix && vp build",
		"lint": "vp lint",
		"format": "vp fmt . --write",
		"preview": "yarn build && vite preview",
		"test": "vp test",
		"test:debug": "vp test --test-timeout=0 --no-file-parallelism",
		"refresh:api": "tsx scripts/refresh-api.ts"
	},
	"dependencies": {
		"@dagrejs/dagre": "^2.0.4",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@monaco-editor/react": "^4.7.0",
		"@mui/icons-material": "^7.3.9",
		"@mui/material": "^7.3.9",
		"@mui/x-data-grid": "^8.28.0",
		"@reduxjs/toolkit": "^2.11.2",
		"@xyflow/react": "^12.10.1",
		"axios": "^1.13.6",
		"inversify": "^8.1.0",
		"jwt-decode": "^4.0.0",
		"monaco-editor": "^0.55.1",
		"oidc-client-ts": "^3.5.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-redux": "^9.2.0",
		"react-router": "^7.13.1",
		"react-router-dom": "^7.13.1",
		"react-toastify": "^11.0.5",
		"reflect-metadata": "^0.2.2"
	},
	"devDependencies": {
		"@elyspio/vite-eslint-config": "5.0.3",
		"@testing-library/react": "^16.3.0",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"jsdom": "^26.1.0",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite-plus": "^0.1.15",
		"vitest": "^4.1.2"
	}
}
